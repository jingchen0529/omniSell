APP_NAME=OmniSell Video Lab API
APP_VERSION=0.1.0
APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000"]
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=omni-sell
AUTH_TOKEN_EXPIRE_HOURS=168
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
DEMO_USER_EMAIL=demo@omnisell.local
DEMO_USER_PASSWORD=demo123456
DEMO_USER_DISPLAY_NAME=Demo Creator
VIDEO_ANALYSIS_PROVIDER=real
VIDEO_TRANSCRIPTION_PROVIDER=faster_whisper
VIDEO_TRANSCRIPTION_LANGUAGE=zh
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
YT_DLP_BINARY=yt-dlp
MEDIA_COMMAND_TIMEOUT_SECONDS=300
FASTER_WHISPER_MODEL_SIZE=small
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_CPU_THREADS=0
FASTER_WHISPER_NUM_WORKERS=1
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_VAD_FILTER=true
FASTER_WHISPER_DOWNLOAD_ROOT=storage/models
# Optional OpenAI-compatible transcription provider:
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_AUDIO_MODEL=whisper-1
# OPENAI_TRANSCRIPTION_LANGUAGE=zh
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_REQUEST_TIMEOUT_SECONDS=120
# ENABLE_AI_ANALYSIS=true
# PROJECT_JOB_RUN_EMBEDDED_WORKER=true
# Optional override:
# DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/omni-sell?charset=utf8mb4
